{
  "name": "mcp-azure-storage",
  "version": "1.0.0",
  "description": "MCP server for Azure Storage — Blob, Queue, Table, and File Share",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "set TEST_INTEGRATION=1&& vitest run --config vitest.integration.config.ts"
  },
  "keywords": [
    "mcp",
    "azure",
    "storage",
    "blob",
    "queue",
    "table",
    "fileshare"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@azure/storage-file-share": "^12.30.0",
    "@azure/storage-queue": "^12.29.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.1.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.1.0"
  }
}
