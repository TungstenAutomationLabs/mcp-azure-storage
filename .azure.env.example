# =============================================================================
# Azure Developer CLI (azd) Environment Variables
# =============================================================================
#
# This is a TEMPLATE showing the variables used by `azd provision` and
# `azd deploy`. You do NOT edit this file directly — azd manages its own
# environment files at .azure/<env-name>/.env.
#
# To set these values, use:
#   azd env set <KEY> "<value>"
#
# ── Required: Set by `azd init` ──────────────────────────────────────────────
# These are prompted during `azd init` and stored automatically.

AZURE_ENV_NAME="mcp-azure-storage-dev"
AZURE_LOCATION="uksouth"
AZURE_SUBSCRIPTION_ID="your-subscription-id"

# ── Required: Set manually ───────────────────────────────────────────────────
# The API key that clients must present to authenticate MCP requests.
# Set this BEFORE running `azd provision`:
#
#   azd env set MCP_API_KEY "your-strong-secret-key-here"
#
# Or generate a random one (macOS/Linux):
#   azd env set MCP_API_KEY "$(openssl rand -base64 24)"
#
# Or generate a random one (Windows PowerShell):
#   azd env set MCP_API_KEY ([Convert]::ToBase64String((1..24 | ForEach-Object { Get-Random -Max 256 }) -as [byte[]]))

MCP_API_KEY="your-strong-secret-key-here"

# ── Optional: Bring Your Own Storage Account (BYOSA) ─────────────────────────
# By default, `azd provision` creates a NEW empty Storage Account in the same
# Resource Group. If you want to connect to an EXISTING Storage Account
# (e.g. one with data already in it), set both of these variables:
#
#   azd env set AZURE_STORAGE_ACCOUNT_NAME "yourstorageaccount"
#   azd env set AZURE_STORAGE_ACCOUNT_KEY "youraccountkey"
#
# When both are set:
#   • No new Storage Account is created by Bicep
#   • Storage RBAC role assignments are skipped
#   • The Container App connects directly using the provided credentials
#   • The existing account can be in any subscription, resource group, or region
#
# To find your storage account key:
#   az storage account keys list --account-name yourstorageaccount --query "[0].value" -o tsv
#
# Leave these EMPTY or unset to provision a new storage account automatically.

AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_ACCOUNT_KEY=""

# ── Optional: CORS ───────────────────────────────────────────────────────────
# CORS is enabled by default (dev-friendly, required for browser-based MCP
# clients like MCP Inspector). Set to "false" in production if the server is
# only consumed by non-browser clients behind a reverse proxy.
#
#   azd env set CORS_ENABLED "false"

CORS_ENABLED="true"

# ── Auto-populated: Set by Bicep outputs after `azd provision` ───────────────
# DO NOT set these manually — they are written automatically by azd after
# infrastructure provisioning completes.

# AZURE_CONTAINER_REGISTRY_ENDPOINT="<acr-name>.azurecr.io"
# mcpEndpoint="https://<app-name>.azurecontainerapps.io/mcp"
# storageAccountName="<storage-account-name>"

# ── Auto-populated: Set by `azd deploy` ─────────────────────────────────────
# Updated each time `azd deploy` pushes a new Docker image.

# SERVICE_MCP_SERVER_IMAGE_NAME="<acr-name>.azurecr.io/<image>:<tag>"
# SERVICE_MCP_SERVER_RESOURCE_EXISTS="true"
